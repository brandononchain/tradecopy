# SignalBridge — Environment Configuration
# Copy this to .env and fill in your values

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Security ────────────────────────────────────────────────────────
# Secret used to sign/verify webhook tokens (change this!)
WEBHOOK_SECRET=change_me_to_a_long_random_string_32chars

# ── MT4 / MT5 Bridge ────────────────────────────────────────────────
# The relay host where your SignalBridge EA connects back to
MT5_RELAY_HOST=https://mt5-relay.signalbridge.io
MT5_API_KEY=your_mt5_bridge_api_key
MT4_RELAY_HOST=https://mt4-relay.signalbridge.io
MT4_API_KEY=your_mt4_bridge_api_key

# ── DX Trade / Liquid Charts ─────────────────────────────────────────
# Host = the domain you log into (NO https://, just the hostname)
# For Liquid Charts: pro.liquidcharts.com
# For FTMO:          dxtrade.ftmo.com
DXTRADE_HOST=pro.liquidcharts.com
DXTRADE_USERNAME=your_liquid_charts_username
DXTRADE_PASSWORD=your_liquid_charts_password
# Account ID shown in the platform (optional, used for position queries)
DXTRADE_ACCOUNT_ID=your_account_number

# ── Tradovate ───────────────────────────────────────────────────────
# Environment: https://live.tradovateapi.com OR https://demo.tradovateapi.com
TRADOVATE_HOST=https://demo.tradovateapi.com
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_SECRET=your_app_secret
TRADOVATE_ACCOUNT_SPEC=your_account_spec

# ── Risk Controls ────────────────────────────────────────────────────
DEFAULT_MAX_POSITION_SIZE=10
DEFAULT_DAILY_LOSS_LIMIT=500
DEFAULT_MAX_SIMULTANEOUS_TRADES=5
DEFAULT_DUPLICATE_WINDOW_SECS=30
